{
  "collectionName": "components_elements_info_cards",
  "info": {
    "displayName": "InfoCard",
    "description": "A generic card: badge, title, text, link and image."
  },
  "options": {},
  "attributes": {
    "badge": {
      "type": "string"
    },
    "badgeColor": {
      "type": "enumeration",
      "enum": ["orange", "sale", "stock", "bronze"],
      "default": "orange"
    },
    "title": {
      "type": "string"
    },
    "text": {
      "type": "text"
    },
    "note": {
      "type": "string"
    },
    "noteColor": {
      "type": "enumeration",
      "enum": ["bronze", "free"],
      "default": "bronze"
    },
    "highlight": {
      "type": "boolean",
      "default": false
    },
    "link": {
      "type": "component",
      "component": "utilities.link",
      "repeatable": false
    },
    "image": {
      "type": "component",
      "component": "utilities.basic-image",
      "repeatable": false
    }
  }
}
