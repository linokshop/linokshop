{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "A ЛінОк catalog product."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "products"
    },
    "brand": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::brand.brand",
      "inversedBy": "products"
    },
    "price": {
      "type": "decimal",
      "required": true
    },
    "oldPrice": {
      "type": "decimal"
    },
    "badge": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "badgeColor": {
      "type": "enumeration",
      "enum": ["bronze", "sale", "stock"],
      "default": "bronze"
    },
    "rating": {
      "type": "decimal"
    },
    "popularity": {
      "type": "integer",
      "default": 0
    },
    "inStock": {
      "type": "boolean",
      "default": true
    },
    "description": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "images": {
      "type": "media",
      "allowedTypes": ["images"],
      "multiple": true
    },
    "specs": {
      "type": "component",
      "component": "elements.spec-row",
      "repeatable": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "options": {
      "type": "component",
      "component": "utilities.text",
      "repeatable": true
    }
  }
}
